PAPER_CODEX_BIND=127.0.0.1:3000
PAPER_CODEX_WORKSPACE=/var/lib/paper-codex/workspace
PAPER_CODEX_STATIC_DIR=/opt/paper-codex/web
PAPER_CODEX_DATABASE_URL=sqlite:///var/lib/paper-codex/workspace/.paper-wiki/state.sqlite?mode=rwc
PAPER_CODEX_CODEX_BIN=/usr/local/bin/codex
PAPER_CODEX_CODEX_HOME=/var/lib/paper-codex/.codex
PAPER_CODEX_PASSWORD_HASH=replace-with-bcrypt-hash
PAPER_CODEX_JWT_SECRET=replace-with-at-least-32-random-bytes
PAPER_CODEX_MAX_UPLOAD_BYTES=104857600
RUST_LOG=paper_codex=info,tower_http=info
